# =============================================================
# FailureAI — Environment Variables Template
# Copy this file to .env and fill in values before running.
# =============================================================

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=true

# ── Database (PostgreSQL) ─────────────────────────────────────
# For Docker Compose (uses service name "postgres"):
DATABASE_URL=postgresql+asyncpg://failureai:failureai@postgres:5432/failureai
# For running backend locally (outside Docker):
# DATABASE_URL=postgresql+asyncpg://failureai:failureai@localhost:5432/failureai

POSTGRES_USER=failureai
POSTGRES_PASSWORD=failureai
POSTGRES_DB=failureai

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# For running backend locally (outside Docker):
# CHROMA_HOST=localhost

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# For running backend locally (outside Docker):
# REDIS_URL=redis://localhost:6379/0

# ── LLM Provider ─────────────────────────────────────────────
# Options: "ollama" | "gemini" | "openai"
LLM_PROVIDER=ollama
LLM_API_KEY=
# Ollama endpoint (host.docker.internal resolves to your host from inside Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Gemini / OpenAI (fill in if LLM_PROVIDER is set to those)
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# ── Auth ─────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── GitHub OAuth (Week 6) ─────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
