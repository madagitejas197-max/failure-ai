# Normalize line endings to LF on commit, checkout as LF on all platforms
* text=auto eol=lf

# Force these to always be LF
*.py      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.cfg     text eol=lf
*.ini     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.sh      text eol=lf
Dockerfile text eol=lf

# Binary files — no line ending conversion
*.png     binary
*.jpg     binary
*.ico     binary
*.woff2   binary
*.woff    binary
